# Environment Variables Template
# Copy this to .env.local for local development
# Set these in your Vercel dashboard for production

# Site Configuration
SITE_URL=https://bernardomoschen.dev
SITE_DOMAIN=bernardomoschen.dev
CONTACT_EMAIL=bernardomoschen.dev@gmail.com

# Email Service (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vercel KV (Upstash Redis) — for the like counter
# Create a KV database in your Vercel dashboard → Storage → KV
# Then link it to the project; these vars are auto-populated in production.
# For local dev, copy them from the Vercel dashboard → KV → .env.local tab.
KV_URL=redis://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KV_REST_API_URL=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.upstash.io
KV_REST_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KV_REST_API_READ_ONLY_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vercel automatically provides these variables:
# VERCEL=1
# VERCEL_URL (preview deployments)
# VERCEL_ENV (development, preview, production)

# Optional: Override site config in different environments
# VERCEL_ENV=production uses SITE_URL above
# VERCEL_ENV=preview uses VERCEL_URL automatically
# VERCEL_ENV=development uses localhost:3000
